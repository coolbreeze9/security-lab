# ─── ESCANEO DE PUERTOS ───────────────────────────────────────────────────────
alert tcp $KALI_ATTACKER any -> $DVWA_SERVER any (msg:"[SCAN] SYN Scan detectado"; flags:S,12; threshold:type threshold, track by_src, count 20, seconds 60; classtype:attempted-recon; sid:3000001; rev:2;)
alert tcp $KALI_ATTACKER any -> $DVWA_SERVER any (msg:"[SCAN] XMAS Scan detectado"; flags:FPU; classtype:attempted-recon; sid:3000002; rev:2;)
alert tcp $KALI_ATTACKER any -> $DVWA_SERVER any (msg:"[SCAN] NULL Scan detectado"; flags:0; classtype:attempted-recon; sid:3000003; rev:3;)
alert tcp $KALI_ATTACKER any -> $DVWA_SERVER any (msg:"[SCAN] FIN Scan detectado"; flags:F; classtype:attempted-recon; sid:3000004; rev:2;)

# ─── SQL INJECTION ────────────────────────────────────────────────────────────
drop http $KALI_ATTACKER any -> $DVWA_SERVER any (msg:"[SQLi] OR 1=1 BLOQUEADO"; flow:to_server,established; content:"OR+1%3D1"; http_uri; nocase; classtype:web-application-attack; sid:3000010; rev:2;)
drop http $KALI_ATTACKER any -> $DVWA_SERVER any (msg:"[SQLi] UNION SELECT BLOQUEADO"; flow:to_server,established; content:"UNION"; nocase; http_uri; content:"SELECT"; nocase; distance:0; within:20; classtype:web-application-attack; sid:3000011; rev:2;)
drop http $KALI_ATTACKER any -> $DVWA_SERVER any (msg:"[TOOL] SQLMap BLOQUEADO"; flow:to_server,established; content:"sqlmap"; http_user_agent; nocase; classtype:web-application-attack; sid:3000013; rev:2;)

# ─── PATH TRAVERSAL / LFI ─────────────────────────────────────────────────────
drop http $KALI_ATTACKER any -> $DVWA_SERVER any (msg:"[LFI] Path Traversal BLOQUEADO"; flow:to_server,established; content:"../"; http_uri; classtype:web-application-attack; sid:3000020; rev:2;)
drop http $KALI_ATTACKER any -> $DVWA_SERVER any (msg:"[LFI] Acceso a /etc/passwd BLOQUEADO"; flow:to_server,established; content:"/etc/passwd"; http_uri; nocase; classtype:web-application-attack; sid:3000021; rev:2;)
drop http $KALI_ATTACKER any -> $DVWA_SERVER any (msg:"[LFI] Acceso a /etc/shadow BLOQUEADO"; flow:to_server,established; content:"/etc/shadow"; http_uri; nocase; classtype:web-application-attack; sid:3000022; rev:2;)

# ─── HERRAMIENTAS DE ATAQUE ───────────────────────────────────────────────────
drop http $KALI_ATTACKER any -> $DVWA_SERVER any (msg:"[TOOL] Nikto Scanner BLOQUEADO"; flow:to_server,established; content:"Nikto"; http_user_agent; nocase; classtype:web-application-attack; sid:3000030; rev:2;)
drop http $KALI_ATTACKER any -> $DVWA_SERVER any (msg:"[TOOL] DirBuster BLOQUEADO"; flow:to_server,established; content:"DirBuster"; http_user_agent; nocase; classtype:web-application-attack; sid:3000031; rev:2;)
drop http $KALI_ATTACKER any -> $DVWA_SERVER any (msg:"[TOOL] Gobuster BLOQUEADO"; flow:to_server,established; content:"gobuster"; http_user_agent; nocase; classtype:web-application-attack; sid:3000032; rev:2;)

# ─── COMMAND INJECTION ───────────────────────────────────────────────────────
drop http $KALI_ATTACKER any -> $DVWA_SERVER any (msg:"[CMDi] Pipe command BLOQUEADO"; flow:to_server,established; content:"%7C"; http_uri; nocase; classtype:web-application-attack; sid:3000040; rev:3;)
drop http $KALI_ATTACKER any -> $DVWA_SERVER any (msg:"[CMDi] Backtick command BLOQUEADO"; flow:to_server,established; content:"`"; http_client_body; classtype:web-application-attack; sid:3000041; rev:2;)
drop http $KALI_ATTACKER any -> $DVWA_SERVER any (msg:"[CMDi] Semicolon command BLOQUEADO"; flow:to_server,established; content:"%3B"; http_uri; nocase; classtype:web-application-attack; sid:3000042; rev:1;)

# ─── XSS ─────────────────────────────────────────────────────────────────────
alert http $KALI_ATTACKER any -> $DVWA_SERVER any (msg:"[XSS] Tag script detectado"; flow:to_server,established; content:"<script"; nocase; http_client_body; classtype:web-application-attack; sid:3000050; rev:2;)
alert http $KALI_ATTACKER any -> $DVWA_SERVER any (msg:"[XSS] Event handler onerror detectado"; flow:to_server,established; content:"onerror"; nocase; http_client_body; classtype:web-application-attack; sid:3000051; rev:2;)
alert http $KALI_ATTACKER any -> $DVWA_SERVER any (msg:"[XSS] Event handler onload detectado"; flow:to_server,established; content:"onload"; nocase; http_client_body; classtype:web-application-attack; sid:3000052; rev:1;)

# ─── FUERZA BRUTA ─────────────────────────────────────────────────────────────
alert http $KALI_ATTACKER any -> $DVWA_SERVER 80 (msg:"[BRUTE] Múltiples intentos de login detectados"; flow:to_server,established; content:"POST"; http_method; content:"login"; http_uri; nocase; threshold:type threshold, track by_src, count 5, seconds 60; classtype:attempted-admin; sid:3000060; rev:2;)
